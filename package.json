{
  "name": "relume-webflow-acostadmacleaning.com",
  "version": "1.0.0",
  "description": "webpack",
  "main": "./app/index.js",
  "author": "ernesto ballon",
  "license": "ISC",
  "scripts": {
    "compress-html": "html-minifier-terser --input-dir ./dist --output-dir ./dist --file-ext html --collapse-whitespace --remove-comments --minify-css --minify-js",
    "compress-js-bundle": "uglifyjs ./dist/bundle.js -o ./dist/bundle.js -c -m",
    "purge-css": "./scripts/purgecss.sh",
    "post-css": "postcss dist/css/*.css --use autoprefixer -d dist/css/ --no-map",
    "optimize-dist": "npm-run-all --parallel compress-html compress-js-bundle purge-css post-css",
    "build": "webpack && npm run optimize-dist",
    "start": "nodemon --watch webpack.* --watch webpack --exec webpack-dev-server",
    "ngrok": "ngrok http http://localhost:3000",
    "pre-commit": "lint-staged",
    "prepare": "husky"
  },
  "devDependencies": {
    "@babel/core": "^7.24.3",
    "@babel/plugin-proposal-class-properties": "^7.8.3",
    "@babel/preset-env": "^7.9.6",
    "@fullhuman/postcss-purgecss": "^6.0.0",
    "@webpack-cli/serve": "^2.0.5",
    "autoprefixer": "^10.4.19",
    "babel-loader": "^8.3.0",
    "babel-register": "^6.26.0",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.10.0",
    "css-minimizer-webpack-plugin": "^6.0.0",
    "cssnano": "^6.1.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "html-minifier-terser": "^7.2.0",
    "html-webpack-plugin": "^5.6.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "mini-css-extract-plugin": "^2.8.1",
    "nodemon": "^2.0.4",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.38",
    "postcss-cli": "^11.0.0",
    "postcss-custom-media": "^10.0.4",
    "postcss-loader": "^8.1.1",
    "postcss-preset-env": "^9.5.4",
    "prettier": "3.2.5",
    "purgecss": "^6.0.0",
    "raw-loader": "^4.0.2",
    "sass": "^1.72.0",
    "sass-loader": "^14.1.1",
    "style-loader": "^1.2.1",
    "tailwindcss": "^3.4.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.3",
    "uglify-js": "^3.17.4",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4",
    "webpack-merge": "^4.2.2"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown",
    "*.js": "eslint --fix"
  }
}
